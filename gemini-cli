#!/usr/bin/env bash
# gemini — Start Claude Playwright bridge (origin IP) and launch Claude Code CLI wired to the bridge
# Usage: CLAUDE_SESSION_KEY=sk-ant-sid02-... ./gemini [claude-args]

set -euo pipefail
# Resolve script directory even when invoked via symlink (e.g., /usr/local/bin/gemini)
if command -v readlink >/dev/null 2>&1; then
  SCRIPT_PATH=$(readlink -f "$0")
else
  SCRIPT_PATH="$0"
fi
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
# Use local gemini server as the backend bridge on localhost:19999
PROXY_PORT=${PROXY_PORT:-19999}
PROXY_LOG="/tmp/gemini-proxy.log"

# Start gemini server if not running
if ! curl -sS "http://localhost:${PROXY_PORT}/health" >/dev/null 2>&1; then
  echo "[gemini] Starting local gemini proxy on :${PROXY_PORT}... (logs: ${PROXY_LOG})"
  node "$ROOT_DIR/gemini/server.mjs" >"$PROXY_LOG" 2>&1 &
  PROXY_PID=$!
  for i in $(seq 1 10); do
    if curl -sf "http://localhost:${PROXY_PORT}/health" >/dev/null 2>&1; then
      echo "[gemini] Proxy ready"
      break
    fi
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      echo "[gemini] Proxy process exited unexpectedly. See ${PROXY_LOG}" >&2
      tail -n 200 "$PROXY_LOG" >&2 || true
      exit 1
    fi
    sleep 1
  done
else
  echo "[gemini] Proxy already running on :${PROXY_PORT}"
fi

# Set environment to route Claude Code CLI via local proxy (Bedrock mode auth bypass)
# Bedrock mode sends requests to /model/{id}/invoke-with-response-stream with ZERO auth headers
# This is the only mode that bypasses the "not logged in" check without a real API key
export CLAUDE_CODE_USE_BEDROCK=1
export CLAUDE_CODE_SKIP_BEDROCK_AUTH=1
export ANTHROPIC_BEDROCK_BASE_URL="http://localhost:${PROXY_PORT}"
export CLAUDE_CODE_TELEMETRY_DISABLED=1
export CLAUDE_CODE_DISABLE_AUTO_UPDATES=1
# Export origin IP for downstream visibility
export ANTHROPIC_ORIGIN_IP="160.79.104.10"

# If ANTHROPIC_API_KEY is set, enable origin mode (bypass Cloudflare → direct Anthropic API)
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  export ANTHROPIC_ORIGIN_MODE=1
  echo "[gemini] Origin mode enabled — Anthropic API via 160.79.104.10 (Cloudflare bypass)"
fi

# Launch Claude Code CLI
# If user didn't provide --model, default to gemini-3.5-flash so the CLI displays Gemini
MODEL_ARG=""
for a in "$@"; do
  case "$a" in
    --model|-m)
      MODEL_ARG=""; break;;
    --model=*)
      MODEL_ARG=""; break;;
  esac
done
if [ -z "$MODEL_ARG" ]; then
  # Prepend default model
  MODEL_ARG="--model gemini-3.5-flash"
fi

echo "[gemini] Launching Claude CLI connected to local proxy @ http://localhost:${PROXY_PORT} (origin IP: ${ANTHROPIC_ORIGIN_IP})"
# Exec claude CLI with model override if needed
exec claude $MODEL_ARG "$@"
