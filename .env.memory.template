# ⚠️ DO NOT COMMIT THIS FILE TO GIT
# It's gitignored. Copy this to .env.memory with your actual secrets.
#
# Restore this file on each new session to give the AI agent its memory.
# Keep a backup somewhere safe (GitHub Gist, encrypted note, etc.)

# ────────────────────────────────────────────
# GitHub Authentication
# ────────────────────────────────────────────
GITHUB_USERNAME=ricksanchez8701
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ────────────────────────────────────────────
# Agent Mothership
# ────────────────────────────────────────────
MOTHERSHIP_AUTH_TOKEN=             # Optional: set a password for the web terminal
MOTHERSHIP_CLOUDFLARE_URL=         # Your Cloudflare Tunnel URL

# ────────────────────────────────────────────
# Session Tracking
# ────────────────────────────────────────────
SESSION_ID=                        # Auto-generated session ID
SESSION_STARTED=                   # Timestamp of current session
